# Copy to backend/.env for local non-docker runs, or set these in Render's dashboard.

# Local default is SQLite; for Postgres use:
# DATABASE_URL=postgresql+psycopg://obrador:obrador@localhost:5432/obradoriq
DATABASE_URL=sqlite:///./obradoriq.db

JWT_SECRET=change-me-to-a-long-random-string
ACCESS_TOKEN_MINUTES=30

# LLM: keep offline (deterministic stubs) unless you want live phrasing.
LLM_OFFLINE=true
# Provider: groq | nvidia | anthropic | openai_compatible. Groq & NVIDIA are free.
LLM_PROVIDER=groq
LLM_API_KEY=
# Optional overrides (otherwise the provider's default models are used):
# MODEL_REASONING=llama-3.3-70b-versatile
# MODEL_EXECUTION=llama-3.1-8b-instant
# LLM_BASE_URL=                       # only for openai_compatible
# ANTHROPIC_API_KEY=                  # only if LLM_PROVIDER=anthropic

# Seed the demo bakery chain on startup.
SEED_ON_START=false
